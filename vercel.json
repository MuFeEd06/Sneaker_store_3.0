{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/api/products(.*)",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, s-maxage=21600, stale-while-revalidate=300"
      }
    },
    {
      "src": "/api/brands",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, s-maxage=21600, stale-while-revalidate=300"
      }
    },
    {
      "src": "/api/offer",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, s-maxage=21600, stale-while-revalidate=300"
      }
    },
    {
      "src": "/api/site-settings",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, s-maxage=21600, stale-while-revalidate=300"
      }
    },
    {
      "src": "/api/search(.*)",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "public, s-maxage=3600, stale-while-revalidate=300"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
